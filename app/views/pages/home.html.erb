<% content_for :title, t("home.meta_title") %>
<% content_for :description, t("home.meta_description") %>

<section class="halftone-field grid gap-10 border-b border-stone-800 pb-10 sm:pb-14 lg:min-h-[72vh] lg:grid-cols-[1.05fr_0.95fr] lg:items-end">
  <div class="relative z-10">
    <h1 class="max-w-4xl text-4xl font-black uppercase leading-none text-white sm:text-5xl md:text-7xl"><%= t("home.title") %></h1>
    <div class="scratch-line mt-6"></div>
    <p class="mt-6 max-w-2xl text-base leading-7 text-stone-300 sm:text-lg sm:leading-8"><%= t("home.intro") %></p>
    <div class="mt-8 flex flex-wrap gap-3">
      <%= link_to t("home.cta_portfolio"), portfolio_path(locale: I18n.locale), class: comic_button_class(variant: :primary, extra: "w-full text-sm sm:w-auto") %>
      <%= link_to t("home.cta_contact"), contact_path(locale: I18n.locale), class: comic_button_class(extra: "w-full text-sm sm:w-auto") %>
    </div>
  </div>

  <div class="relative z-10 -mx-4 flex snap-x snap-mandatory gap-4 overflow-x-auto px-4 pb-8 sm:mx-0 sm:grid sm:grid-cols-3 sm:gap-3 sm:overflow-visible sm:px-0">
    <% @hero_artworks.each do |artwork| %>
      <figure class="home-feature-card panel-frame ink-panel min-h-72 w-[76vw] shrink-0 snap-center p-2 sm:min-h-72 sm:w-auto lg:min-h-80">
        <% if artwork.image.attached? %>
          <%= image_tag artwork.image.variant(:thumb), alt: artwork.alt_text, class: "home-feature-image h-full min-h-72 w-full object-cover sm:min-h-72 lg:min-h-80" %>
        <% else %>
          <div class="grid h-full min-h-72 place-items-center bg-neutral-900 p-4 text-center text-xs font-black uppercase text-stone-500 sm:min-h-72 lg:min-h-80">
            <%= artwork.title %>
          </div>
        <% end %>
      </figure>
    <% end %>

    <% if @recent_artworks.empty? %>
      <div class="panel-frame ink-panel col-span-3 p-6">
        <p class="text-sm uppercase text-stone-500"><%= t("home.focus") %></p>
        <ul class="mt-4 space-y-3 text-2xl font-black uppercase text-white">
          <li>Sample pages</li>
          <li>Sequential art</li>
          <li>Commissions</li>
        </ul>
      </div>
    <% end %>
  </div>
</section>

<section class="mt-12 sm:mt-16">
  <div class="mb-6">
    <h2 class="text-2xl font-black uppercase"><%= t("home.latest") %></h2>
  </div>

  <%= render "portfolio/artwork_grid", artworks: @recent_artworks %>

  <div class="mt-8 flex justify-center">
    <%= link_to t("home.view_all"), portfolio_path(locale: I18n.locale), class: comic_button_class(extra: "text-sm") %>
  </div>
</section>
