<% content_for :title, t("about.meta_title") %>
<% content_for :description, t("about.meta_description") %>

<section class="grid gap-10 lg:grid-cols-[0.88fr_1.12fr] lg:items-center">
  <div class="halftone-field">
    <figure class="about-portrait ink-panel panel-frame max-w-sm p-3">
      <%= image_tag "gabriel-avatar.jpg", alt: t("about.avatar_alt"), class: "about-portrait-image aspect-square w-full object-cover" %>
    </figure>
  </div>

  <div>
    <p class="mb-4 text-sm font-bold uppercase text-violet-300"><%= t("about.eyebrow") %></p>
    <h1 class="text-4xl font-black uppercase text-white md:text-6xl"><%= t("about.title") %></h1>
    <div class="scratch-line mt-6"></div>
    <p class="mt-6 text-lg leading-8 text-stone-300"><%= t("about.body") %></p>

    <div class="mt-12">
      <dl class="contents">
        <div class="grid gap-10 sm:grid-cols-2 sm:gap-14">
          <div class="floating-stat">
            <dt class="text-xs font-black uppercase text-orange-300"><%= t("about.focus_label") %></dt>
            <dd class="mt-2 max-w-48 text-base leading-7 text-stone-200"><%= t("about.focus") %></dd>
          </div>
          <div class="floating-stat">
            <dt class="text-xs font-black uppercase text-orange-300"><%= t("about.market_label") %></dt>
            <dd class="mt-2 max-w-48 text-base leading-7 text-stone-200"><%= t("about.market") %></dd>
          </div>
        </div>
      </dl>

      <%= image_tag "gabriel-signature.jpg", alt: t("about.signature_alt"), class: "signature-mark mt-10 h-24 w-24 border border-stone-800 object-cover" %>
    </div>
  </div>
</section>
