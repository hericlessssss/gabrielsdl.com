<h1>Nova mensagem pelo site</h1>

<p><strong>Nome:</strong> <%= @contact_message.name %></p>
<p><strong>E-mail:</strong> <%= mail_to @contact_message.email %></p>
<p><strong>Idioma:</strong> <%= @contact_message.locale %></p>
<p><strong>Origem:</strong> <%= @contact_message.source %></p>

<p><strong>Mensagem:</strong></p>
<p><%= simple_format(@contact_message.message) %></p>
