<% content_for :title, t("contact.meta_title") %>
<% content_for :description, t("contact.meta_description") %>

<section class="grid gap-10 lg:grid-cols-[0.8fr_1.2fr]">
  <div class="halftone-field border-b border-stone-800 pb-8 lg:border-b-0 lg:pb-0">
    <p class="mb-4 text-sm font-bold uppercase text-orange-300"><%= t("contact.eyebrow") %></p>
    <h1 class="text-4xl font-black uppercase text-white md:text-6xl"><%= t("contact.title") %></h1>
    <div class="scratch-line mt-6"></div>
    <p class="mt-6 text-lg leading-8 text-stone-300"><%= t("contact.body") %></p>

    <div class="mt-8 space-y-4">
      <%= mail_to t("contact.public_email"), nil, class: "contact-link text-lg font-black uppercase text-orange-300 hover:text-orange-200" do %>
        <span class="contact-icon contact-icon-mail" aria-hidden="true"></span>
        <span><%= t("contact.public_email") %></span>
      <% end %>
      <%= link_to t("contact.instagram_url"), class: "contact-link text-lg font-black uppercase text-violet-300 hover:text-violet-200", target: "_blank", rel: "noopener" do %>
        <span class="contact-icon contact-icon-instagram" aria-hidden="true"></span>
        <span><%= t("contact.instagram") %></span>
      <% end %>
    </div>
  </div>

  <%= form_with model: @contact_message, url: contact_messages_path(locale: I18n.locale), class: "contact-form-panel panel-frame space-y-5 p-5 sm:p-7" do |form| %>
    <% if @contact_message.errors.any? %>
      <div class="border border-red-500/40 bg-red-950/40 p-4 text-sm text-red-100">
        <p class="font-bold"><%= t("contact.errors") %></p>
        <ul class="mt-2 list-disc space-y-1 pl-5">
          <% @contact_message.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div>
      <%= form.label :name, t("contact.name"), class: "mb-2 block text-sm font-bold uppercase text-stone-300" %>
      <%= form.text_field :name, class: "w-full border border-stone-700 bg-neutral-900 px-4 py-3 text-white" %>
    </div>

    <div>
      <%= form.label :email, t("contact.email"), class: "mb-2 block text-sm font-bold uppercase text-stone-300" %>
      <%= form.email_field :email, class: "w-full border border-stone-700 bg-neutral-900 px-4 py-3 text-white" %>
    </div>

    <div>
      <%= form.label :message, t("contact.message"), class: "mb-2 block text-sm font-bold uppercase text-stone-300" %>
      <%= form.text_area :message, rows: 7, class: "w-full border border-stone-700 bg-neutral-900 px-4 py-3 text-white" %>
    </div>

    <%= form.submit t("contact.submit"), class: comic_button_class(variant: :primary, extra: "w-full text-sm sm:w-auto") %>
  <% end %>
</section>
