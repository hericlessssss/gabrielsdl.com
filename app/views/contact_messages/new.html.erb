<section class="grid gap-10 lg:grid-cols-[0.8fr_1.2fr]">
  <div>
    <p class="mb-4 text-sm font-bold uppercase text-orange-300"><%= t("contact.eyebrow") %></p>
    <h1 class="text-4xl font-black uppercase text-white md:text-6xl"><%= t("contact.title") %></h1>
    <p class="mt-6 text-lg leading-8 text-stone-300"><%= t("contact.body") %></p>
  </div>

  <%= form_with model: @contact_message, url: contact_messages_path(locale: I18n.locale), class: "space-y-5" do |form| %>
    <% if @contact_message.errors.any? %>
      <div class="border border-red-500/40 bg-red-950/40 p-4 text-sm text-red-100">
        <p class="font-bold"><%= t("contact.errors") %></p>
      </div>
    <% end %>

    <div>
      <%= form.label :name, t("contact.name"), class: "mb-2 block text-sm font-bold uppercase text-stone-300" %>
      <%= form.text_field :name, class: "w-full border border-stone-700 bg-neutral-900 px-4 py-3 text-white" %>
    </div>

    <div>
      <%= form.label :email, t("contact.email"), class: "mb-2 block text-sm font-bold uppercase text-stone-300" %>
      <%= form.email_field :email, class: "w-full border border-stone-700 bg-neutral-900 px-4 py-3 text-white" %>
    </div>

    <div>
      <%= form.label :message, t("contact.message"), class: "mb-2 block text-sm font-bold uppercase text-stone-300" %>
      <%= form.text_area :message, rows: 7, class: "w-full border border-stone-700 bg-neutral-900 px-4 py-3 text-white" %>
    </div>

    <%= form.submit t("contact.submit"), class: "bg-orange-500 px-5 py-3 text-sm font-black uppercase text-neutral-950 hover:bg-orange-400" %>
  <% end %>
</section>
