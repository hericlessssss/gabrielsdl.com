<!DOCTYPE html>
<html>
  <head>
    <title><%= page_title %></title>
    <meta name="description" content="<%= page_description %>">
    <link rel="canonical" href="<%= url_for(only_path: false) %>">
    <link rel="alternate" hreflang="pt" href="<%= alternate_locale_url(:pt) %>">
    <link rel="alternate" hreflang="en" href="<%= alternate_locale_url(:en) %>">
    <meta property="og:site_name" content="<%= t("site.brand") %>">
    <meta property="og:title" content="<%= page_title %>">
    <meta property="og:description" content="<%= page_description %>">
    <meta property="og:type" content="website">
    <meta property="og:url" content="<%= url_for(only_path: false) %>">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Gabriel Santos">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="site-shell text-stone-100 antialiased">
    <header class="sticky top-0 z-40 border-b border-stone-800/80 bg-neutral-950/85 backdrop-blur">
      <nav class="mx-auto flex max-w-6xl flex-wrap items-center justify-between gap-4 px-4 py-4 sm:px-5">
        <%= link_to t("site.brand"), localized_root_path(locale: I18n.locale), class: "min-w-0 text-base font-black uppercase tracking-wide sm:text-lg" %>

        <div class="flex flex-wrap items-center justify-end gap-2 text-xs text-stone-300 sm:gap-3 sm:text-sm">
          <%= navigation_link t("navigation.portfolio"), portfolio_path(locale: I18n.locale), active: controller_name == "portfolio" %>
          <%= navigation_link t("navigation.about"), about_path(locale: I18n.locale), active: controller_name == "pages" && action_name == "about" %>
          <%= navigation_link t("navigation.contact"), contact_path(locale: I18n.locale), active: controller_name == "contact_messages" %>
          <span class="ml-1 flex items-center gap-2">
            <%= link_to url_for(locale: :pt), class: "locale-link", aria: { label: "Português" } do %>
              <span class="flag-icon flag-br" aria-hidden="true"></span>
              <span>PT</span>
            <% end %>
            <%= link_to url_for(locale: :en), class: "locale-link", aria: { label: "English" } do %>
              <span class="flag-icon flag-us" aria-hidden="true"></span>
              <span>EN</span>
            <% end %>
          </span>
        </div>
      </nav>
    </header>

    <main class="mx-auto max-w-6xl px-4 py-8 sm:px-5 sm:py-12">
      <% if notice.present? %>
        <p class="mb-6 border border-emerald-500/40 bg-emerald-950/50 px-4 py-3 text-sm text-emerald-100"><%= notice %></p>
      <% end %>

      <%= yield %>
    </main>
  </body>
</html>
