<% if artwork_groups.any? %>
  <div class="space-y-12">
    <% artwork_groups.each do |group, artworks| %>
      <section>
        <div class="mb-5 border-b border-stone-800 pb-4">
          <p class="text-xs font-black uppercase text-orange-300">
            <%= group.is_a?(Project) ? t("portfolio.sequence") : group.name %>
          </p>
          <h2 class="mt-2 text-2xl font-black uppercase text-white"><%= group.is_a?(Project) ? group.title : group.name %></h2>
          <% if group.is_a?(Project) && group.summary.present? %>
            <p class="mt-2 max-w-2xl text-sm leading-6 text-stone-400"><%= group.summary %></p>
          <% end %>
        </div>

        <%= render "portfolio/artwork_grid", artworks: artworks %>
      </section>
    <% end %>
  </div>
<% else %>
  <p class="border border-stone-800 bg-neutral-900 p-6 text-stone-400"><%= t("portfolio.empty") %></p>
<% end %>
