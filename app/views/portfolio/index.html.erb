<% content_for :title, t("portfolio.meta_title") %>
<% content_for :description, t("portfolio.meta_description") %>

<%= turbo_frame_tag "portfolio_content" do %>
  <section>
    <p class="mb-4 text-sm font-bold uppercase text-orange-300"><%= t("portfolio.eyebrow") %></p>
    <h1 class="text-4xl font-black uppercase text-white md:text-6xl"><%= t("portfolio.title") %></h1>

    <nav class="mt-8 flex flex-wrap gap-3" aria-label="<%= t("portfolio.filters") %>">
      <%= link_to t("portfolio.all"), portfolio_path(locale: I18n.locale), data: { turbo_frame: "portfolio_content" }, aria: { current: ("page" unless @current_category) }, class: comic_button_class(active: @current_category.blank?, extra: "text-sm") %>
      <% @categories.each do |category| %>
        <%= link_to category.name, portfolio_path(locale: I18n.locale, category: category.slug), data: { turbo_frame: "portfolio_content" }, aria: { current: ("page" if @current_category == category) }, class: comic_button_class(active: @current_category == category, extra: "text-sm") %>
      <% end %>
    </nav>
  </section>

  <section class="mt-10">
    <p class="mb-4 text-sm uppercase text-stone-500"><%= t("portfolio.count", count: @artworks.size) %></p>
    <%= render "portfolio/artwork_groups", artwork_groups: @artwork_groups %>
  </section>
<% end %>
